# Environment files with secrets
.env
.env.local
.env.*.local
.env.production
admin-dashboard/.env*
frontend/.env*
vendor-dashboard/.env*

# Production configs with credentials
application-prod.yml
application-production.yml
**/src/main/resources/application-prod.yml

# Kubernetes secrets
k8s/*secrets*
k8s/02-secrets.yaml

# API keys, passwords, certificates
*.key
*.pem
credentials.json
aws-credentials
.aws/

